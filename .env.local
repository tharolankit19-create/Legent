# Legent local environment template.
# Fill these values locally. Never commit real production secrets.

# AI: OpenRouter (default model: anthropic/claude-sonnet-4-5)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# Database: Neon PostgreSQL
DATABASE_URL=

# Upstash Redis / QStash scheduler
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
QSTASH_TOKEN=

# Dodo Payments (never Stripe)
DODO_API_KEY=
DODO_WEBHOOK_SECRET=

# Email: Resend
RESEND_API_KEY=

# Auth: NextAuth.js
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Storage: Cloudflare R2
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ENDPOINT=

# X / Twitter API
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=

# LinkedIn API
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# App URLs
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Security: generate a 32-byte key and store as 64 hex characters for AES-256 token encryption.
TOKEN_ENCRYPTION_KEY=
