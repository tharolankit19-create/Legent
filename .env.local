# ===========================================
# LEGENT — ENVIRONMENT VARIABLES (MVP)
# Copy this file to .env.local and fill values
# NEVER commit real secrets
# ===========================================

# --- DATABASE (Neon PostgreSQL - REQUIRED) ---
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# --- UPSTASH REDIS / QSTASH (for scheduler) ---
UPSTASH_REDIS_URL=""
UPSTASH_REDIS_TOKEN=""
QSTASH_TOKEN=""                    # For QStash scheduling

# --- OPENROUTER AI (Core AI) ---
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="anthropic/claude-sonnet-4-5"   # Default model

# --- DODO PAYMENTS (Billing - DO NOT USE STRIPE) ---
DODO_API_KEY=""
DODO_WEBHOOK_SECRET=""

# --- RESEND (Email) ---
RESEND_API_KEY=""

# --- NEXTAUTH (Auth) ---
NEXTAUTH_SECRET="generate-a-secure-32-char-random-string-here"
NEXTAUTH_URL="http://localhost:3000"   # Change to your Vercel URL in prod

# --- GOOGLE OAUTH ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- CLOUDflare R2 (Media Storage) ---
CLOUDFLARE_R2_ACCESS_KEY=""
CLOUDFLARE_R2_SECRET_KEY=""
CLOUDFLARE_R2_BUCKET="legent-media"
CLOUDFLARE_R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"

# --- X (Twitter) API v2 ---
X_API_KEY=""
X_API_SECRET=""
X_ACCESS_TOKEN=""          # For initial testing (later use OAuth)
X_ACCESS_TOKEN_SECRET=""

# --- LINKEDIN API ---
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# --- FRONTEND / APP URLS ---
FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- OPTIONAL: ENCRYPTION KEY for tokens (AES-256) ---
TOKEN_ENCRYPTION_KEY="32-byte-hex-key-for-aes-256-encryption"
