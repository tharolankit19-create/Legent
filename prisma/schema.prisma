// Legent — AI-agent-first social media management SaaS
// Phase 1 MVP schema for Neon PostgreSQL + Prisma ORM.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanType {
  FREE
  STARTER
  PRO
  EARLY_ACCESS
}

enum PlanStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
}

enum Platform {
  X
  LINKEDIN
  INSTAGRAM
  THREADS
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

enum AgentDraftStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum AgentPostStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SCHEDULED
}

enum PaymentProvider {
  DODO
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  avatar        String?
  image         String?
  passwordHash  String?
  emailVerified DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization Organization?
  accounts     Account[]
  sessions     Session[]
  waitlistEntry WaitlistEntry?

  @@index([email])
}

model Organization {
  id          String     @id @default(cuid())
  name        String
  userId      String     @unique
  planType    PlanType   @default(FREE)
  planStatus  PlanStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription  Subscription?
  integrations  Integration[]
  posts         Post[]
  agentDrafts   AgentDraft[]

  @@index([planType, planStatus])
}

model Subscription {
  id                 String          @id @default(cuid())
  orgId              String          @unique
  provider           PaymentProvider @default(DODO)
  dodoSubscriptionId String?         @unique
  dodoCustomerId     String?
  planType           PlanType
  status             PlanStatus      @default(ACTIVE)
  currentPeriodEnd   DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Integration {
  id           String   @id @default(cuid())
  orgId        String
  platform     Platform
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  username     String?
  avatar       String?
  isActive     Boolean  @default(true)
  expiresAt    DateTime?
  scopes       String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, platform])
  @@index([orgId, isActive])
}

model Post {
  id            String     @id @default(cuid())
  orgId         String
  agentDraftId  String?
  content       String     @db.Text
  platforms     Platform[]
  scheduledAt   DateTime?
  publishedAt   DateTime?
  status        PostStatus @default(DRAFT)
  aiScore       Int?
  aiSuggestions Json?
  failureReason String?    @db.Text
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  agentDraft   AgentDraft?  @relation(fields: [agentDraftId], references: [id], onDelete: SetNull)
  analytics    Analytics[]

  @@index([orgId, status])
  @@index([scheduledAt])
  @@index([publishedAt])
}

model Analytics {
  id          String   @id @default(cuid())
  postId      String
  platform    Platform
  impressions Int      @default(0)
  engagements Int      @default(0)
  clicks      Int      @default(0)
  fetchedAt   DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, platform, fetchedAt])
  @@index([postId])
  @@index([platform, fetchedAt])
}

model AgentDraft {
  id            String           @id @default(cuid())
  orgId         String
  weekStartDate DateTime
  posts         Json
  status        AgentDraftStatus @default(PENDING_APPROVAL)
  agentNotes    String?          @db.Text
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  scheduledPosts Post[]

  @@unique([orgId, weekStartDate])
  @@index([orgId, status])
}

model WaitlistEntry {
  id               String   @id @default(cuid())
  email            String   @unique
  userId           String?  @unique
  referralCode     String   @unique
  referredByCode   String?
  referralCount    Int      @default(0)
  earlyAccessPaid  Boolean  @default(false)
  dodoPaymentId    String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([referredByCode])
}

// NextAuth.js adapter models. Legent uses JWT sessions, but these are kept for OAuth account linking.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
